Root CA cert (install this in Checkmk):
bashkubectl get secret root-ca-secret -n cert-manager \
  -o jsonpath='{.data.tls\.crt}' | base64 -d > thanos-k3s-root-ca.crt
Intermediate CA cert:
bashkubectl get secret intermediate-ca-secret -n cert-manager \
  -o jsonpath='{.data.tls\.crt}' | base64 -d > thanos-k3s-intermediate-ca.crt
NetApp mock cert:
bashkubectl get secret netapp-mock-tls-secret -n netapp-mock \
  -o jsonpath='{.data.tls\.crt}' | base64 -d > netapp-mock.crt

