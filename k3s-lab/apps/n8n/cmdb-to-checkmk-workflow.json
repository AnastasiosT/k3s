{
  "id": "cmdb-to-checkmk",
  "name": "CMDB to Checkmk Sync",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 1
            }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Every Hour",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "url": "http://cmdb/api/devices",
        "authentication": "none",
        "options": {}
      },
      "id": "get-cmdb-devices",
      "name": "Get Devices from CMDB",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [460, 300]
    },
    {
      "parameters": {
        "jsCode": "const devices = $input.item.json.results || [];\nreturn devices.map(device => ({\n  json: {\n    hostname: device.hostname,\n    ip_address: device.ip,\n    device_type: device.device_type,\n    location: device.location\n  }\n}));"
      },
      "id": "transform-devices",
      "name": "Transform Devices",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "url": "https://checkmk.k3s.local/v250/check_mk/api/1.0/domain-types/host/collections/all",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpBasicAuth",
        "options": {
          "allowUnauthorizedCerts": true
        }
      },
      "id": "get-checkmk-hosts",
      "name": "Get Hosts from Checkmk",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [900, 300]
    },
    {
      "parameters": {
        "jsCode": "const checkmkResponse = $input.item.json;\nconst checkmkHosts = checkmkResponse.value || [];\nconst checkmkHostnames = checkmkHosts.map(h => h.id);\n\nconst transformNode = $('Transform Devices');\nconst cmdbDevices = transformNode.all();\n\nconst newHosts = [];\nfor (const item of cmdbDevices) {\n  const hostname = item.json.hostname;\n  if (hostname && !checkmkHostnames.includes(hostname)) {\n    newHosts.push({ json: item.json });\n  }\n}\n\nif (newHosts.length === 0) {\n  console.log('No new hosts to add - all CMDB devices already in Checkmk');\n  return [];\n}\n\nconsole.log(`Found ${newHosts.length} new hosts to add`);\nreturn newHosts;"
      },
      "id": "find-missing-hosts",
      "name": "Find Missing Hosts",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://checkmk.k3s.local/v250/check_mk/api/1.0/domain-types/host_config/collections/all",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpBasicAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { host_name: $json.hostname, folder: '/', attributes: { ipaddress: $json.ip_address, alias: $json.hostname + ' (' + $json.device_type + ')', site: 'iframe' } } }}",
        "options": {
          "allowUnauthorizedCerts": true
        }
      },
      "id": "create-host",
      "name": "Create Host in Checkmk",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1340, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://checkmk.k3s.local/v250/check_mk/api/1.0/domain-types/activation_run/actions/activate-changes/invoke",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpBasicAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "If-Match",
              "value": "*"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { sites: ['iframe'], force_foreign_changes: true } }}",
        "options": {
          "allowUnauthorizedCerts": true
        }
      },
      "id": "activate-changes",
      "name": "Activate Changes",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1560, 300],
      "onError": "continueRegularOutput"
    }
  ],
  "connections": {
    "Every Hour": {
      "main": [
        [
          {
            "node": "Get Devices from CMDB",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get Devices from CMDB": {
      "main": [
        [
          {
            "node": "Transform Devices",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Transform Devices": {
      "main": [
        [
          {
            "node": "Get Hosts from Checkmk",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get Hosts from Checkmk": {
      "main": [
        [
          {
            "node": "Find Missing Hosts",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Find Missing Hosts": {
      "main": [
        [
          {
            "node": "Create Host in Checkmk",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Create Host in Checkmk": {
      "main": [
        [
          {
            "node": "Activate Changes",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
